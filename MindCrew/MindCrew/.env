# ═══════════════════════════════════════════════════════════════════
# MindCrew · 开发环境变量模板（docker-compose.yml 用）
# 用法：复制为 .env，按需修改，然后 docker compose up -d
#
# .env 已加入 .gitignore，本文件 .env.example 不含真实密钥可以提交
# ═══════════════════════════════════════════════════════════════════

# ── 必填 · 阿里云百炼 API Key ──
# 申请地址: https://bailian.console.aliyun.com/?apiKey=1
BAILIAN_API_KEY=REPLACE_WITH_YOUR_BAILIAN_API_KEY

# ── 可选 · Tavily Web 搜索 API Key ──
# https://app.tavily.com/sign-in 注册后免费 1000 次/月
TAVILY_API_KEY=

# ── 端口（默认值如有冲突可改） ──
FRONTEND_PORT=80
BACKEND_PORT=8080
MYSQL_PORT=3307
REDIS_PORT=6379
MILVUS_PORT=19530
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── 数据库 / 缓存默认凭证（开发环境可用默认） ──
MYSQL_ROOT_PASSWORD=Mindcrew123456
REDIS_PASSWORD=
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── 存储模式 ──
# minio  · 本地 MinIO（开发默认）
# oss    · 阿里云 OSS（需填下方 OSS_* 参数）
STORAGE_TYPE=minio

# ── 阿里云 OSS（STORAGE_TYPE=oss 时必填） ──
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_REGION=cn-beijing
OSS_BUCKET=mindcrew-prod
OSS_ACCESS_KEY=REPLACE_WITH_YOUR_OSS_ACCESS_KEY
OSS_SECRET_KEY=REPLACE_WITH_YOUR_OSS_SECRET_KEY

# ── JVM 调优 ──
JAVA_OPTS=-Xms512m -Xmx2048m -XX:+UseG1GC

# ── 加密主密钥（生产必改 · 32 字符以上随机串） ──
CRYPTO_MASTER_KEY=REPLACE_WITH_RANDOM_32_PLUS_CHAR_SECRET

# 阿里账单
BSS_ENABLED=true
BSS_ACCESS_KEY=REPLACE_WITH_YOUR_BSS_ACCESS_KEY
BSS_SECRET_KEY=REPLACE_WITH_YOUR_BSS_SECRET_KEY
